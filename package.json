{
  "name": "decklist-assistant",
  "version": "6.1.0",
  "private": true,
  "description": "Assistente open source para preenchimento da função Comprar por Lista.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/verify-build.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/tampermonkey": "^5.0.4",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vite-plugin-monkey": "^5.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
